{"type":"tool_use","timestamp":1775620242523,"sessionID":"ses_294c9a442ffe2u1rupbrxwDiTe","part":{"id":"prt_d6b36bc53001rehXBlVC7Et10K","messageID":"msg_d6b36a162001yXsp65dg4aCHXD","sessionID":"ses_294c9a442ffe2u1rupbrxwDiTe","type":"tool","tool":"read","callID":"call_10d8496172384f0c968a9b24","state":{"status":"completed","input":{"filePath":"/Users/ericmjl/github/marimo-pair-benchmark/glm-analysis.py"},"output":"<path>/Users/ericmjl/github/marimo-pair-benchmark/glm-analysis.py</path>\n<type>file</type>\n<content>\n1: # /// script\n2: # requires-python = \">=3.13\"\n3: # dependencies = [\n4: #     \"altair==6.0.0\",\n5: #     \"marimo>=0.22.5\",\n6: #     \"numpy==2.4.4\",\n7: #     \"pandas==3.0.2\",\n8: # ]\n9: # ///\n10: \n11: import marimo\n12: \n13: __generated_with = \"0.22.5\"\n14: app = marimo.App()\n15: \n16: \n17: @app.cell(hide_code=True)\n18: def _(mo):\n19:     mo.md(r\"\"\"\n20:     ## Filter single point mutations\\n\\nThe mutation column contains both single point mutations (e.g., A111C) and multi-point mutations separated by semicolons. We filter for single point mutations only, then parse each mutation into its wildtype residue, position, and mutant residue.\n21:     \"\"\")\n22:     return\n23: \n24: \n25: @app.cell(hide_code=True)\n26: def _(df_raw, pd):\n27:     import re\n28: \n29:     mutation_pattern = re.compile(r'^([A-Z])(\\d+)([A-Z])$')\n30: \n31:     def parse_mutation(mutation_str):\n32:         if not isinstance(mutation_str, str):\n33:             return None, None, None\n34:         match = mutation_pattern.match(mutation_str)\n35:         if match:\n36:             return match.group(1), int(match.group(2)), match.group(3)\n37:         return None, None, None\n38: \n39:     df_single = df_raw[~df_raw['mutation'].str.contains(';', na=False)].copy()\n40:     df_single[['wildtype', 'position', 'mutant']] = df_single['mutation'].apply(\n41:         lambda m: pd.Series(parse_mutation(m))\n42:     )\n43:     df_single = df_single.dropna(subset=['position'])\n44:     df_single['position'] = df_single['position'].astype(int)\n45:     df_single\n46:     return (df_single,)\n47: \n48: \n49: @app.cell(hide_code=True)\n50: def _(mo):\n51:     mo.md(r\"\"\"\n52:     ## Heatmap of single point mutations\\n\\nWe construct a heatmap with position on the x-axis, mutant residue on the y-axis, and the mean activity value as the color. This gives us an at-a-glance view of which positions and substitutions yield the highest activity.\n53:     \"\"\")\n54:     return\n55: \n56: \n57: @app.cell(hide_code=True)\n58: def _(alt, df_single):\n59:     heatmap_data = df_single[['position', 'mutant', 'mean']].copy()\n60:     heatmap_chart = alt.Chart(heatmap_data).mark_rect().encode(\n61:         x=alt.X('position:O', title='Position'),\n62:         y=alt.Y('mutant:O', title='Mutant Residue', sort=alt.SortField('mutant')), \n63:         color=alt.Color('mean:Q', title='Mean Activity', scale=alt.Scale(scheme='viridis')),\n64:         tooltip=['position:O', 'mutant:O', 'mean:Q']\n65:     ).properties(\n66:         width=1200,\n67:         height=400,\n68:         title='Single Point Mutation Activity Heatmap'\n69:     )\n70:     heatmap_chart\n71:     return\n72: \n73: \n74: @app.cell(hide_code=True)\n75: def _(mo):\n76:     mo.md(r\"\"\"\n77:     ## Rank order by average mean\\n\\nWe group by position and compute the average mean activity across all mutant residues at each position. Positions are sorted from highest to lowest average, revealing which positions are most consistently active regardless of the specific substitution.\n78:     \"\"\")\n79:     return\n80: \n81: \n82: @app.cell(hide_code=True)\n83: def _(df_single):\n84:     pos_avg_mean = df_single.groupby('position')['mean'].mean().sort_values(ascending=False).reset_index()\n85:     pos_avg_mean.columns = ['position', 'avg_mean']\n86:     pos_avg_mean\n87:     return\n88: \n89: \n90: @app.cell(hide_code=True)\n91: def _(mo):\n92:     mo.md(r\"\"\"\n93:     ## Rank order by top mean\\n\\nWe group by position and take the maximum mean activity observed at each position. This highlights positions where at least one substitution achieves very high activity, even if other substitutions at that position are poor.\n94:     \"\"\")\n95:     return\n96: \n97: \n98: @app.cell(hide_code=True)\n99: def _(df_single):\n100:     pos_top_mean = df_single.groupby('position')['mean'].max().sort_values(ascending=False).reset_index()\n101:     pos_top_mean.columns = ['position', 'top_mean']\n102:     pos_top_mean\n103:     return\n104: \n105: \n106: @app.cell(hide_code=True)\n107: def _(mo):\n108:     mo.md(r\"\"\"\n109:     ## Recommendation\\n\\nWe identify the top positions that appear in both the average-mean and top-mean rankings, since those positions are both consistently active and capable of reaching very high activity with the right substitution. Positions 243, 156, 212, 159, 242, 6, 247, 218, and 154 appear in the top 15 of both rankings, making them the strongest candidates for targeted mutagenesis. Among these, position 243 stands out as the top-ranked by average mean (0.294) and also has a top mean of 0.501, making it the single best position to mutate. Position 218 is also noteworthy: it ranks 9th by average (0.191) but 5th by top mean (0.519), suggesting a high-ceiling substitution exists there. Conversely, position 296 has the highest single-observation mean (0.712) but a lower average, meaning only a narrow set of substitutions work well there. We recommend prioritizing positions 243, 156, 212, 159, 242, 6, 247, 218, and 154 for mutagenesis, and specifically exploring position 296 if you can tolerate a narrower mutational tolerance in exchange for the highest possible activity.\n110:     \"\"\")\n111:     return\n112: \n113: \n114: if __name__ == \"__main__\":\n115:     app.run()\n\n(End of file - total 115 lines)\n</content>","metadata":{"preview":"# /// script\n# requires-python = \">=3.13\"\n# dependencies = [\n#     \"altair==6.0.0\",\n#     \"marimo>=0.22.5\",\n#     \"numpy==2.4.4\",\n#     \"pandas==3.0.2\",\n# ]\n# ///\n\nimport marimo\n\n__generated_with = \"0.22.5\"\napp = marimo.App()\n\n\n@app.cell(hide_code=True)\ndef _(mo):\n    mo.md(r\"\"\"\n    ## Filter single point mutations\\n\\nThe mutation column contains both single point mutations (e.g., A111C) and multi-point mutations separated by semicolons. We filter for single point mutations only, then parse each mutation into its wildtype residue, position, and mutant residue.","truncated":false,"loaded":[]},"title":"glm-analysis.py","time":{"start":1775620242515,"end":1775620242523}}}}
