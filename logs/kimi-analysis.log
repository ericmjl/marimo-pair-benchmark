{"type":"tool_use","timestamp":1775620415309,"sessionID":"ses_294c9a4d9ffeSwOQKf2XzFA0yJ","part":{"id":"prt_d6b395ef300167tkri7w2X26pm","messageID":"msg_d6b39472a001IxvRhc74dkDg2Q","sessionID":"ses_294c9a4d9ffeSwOQKf2XzFA0yJ","type":"tool","tool":"read","callID":"read:17","state":{"status":"completed","input":{"filePath":"/Users/ericmjl/github/marimo-pair-benchmark/kimi-analysis.py"},"output":"<path>/Users/ericmjl/github/marimo-pair-benchmark/kimi-analysis.py</path>\n<type>file</type>\n<content>\n1: # /// script\n2: # requires-python = \">=3.13\"\n3: # dependencies = [\n4: #     \"marimo>=0.22.5\",\n5: #     \"matplotlib==3.10.8\",\n6: #     \"numpy==2.4.4\",\n7: #     \"pandas==3.0.2\",\n8: #     \"seaborn==0.13.2\",\n9: #     \"upsetplot==0.9.0\",\n10: # ]\n11: # ///\n12: \n13: import marimo\n14: \n15: __generated_with = \"0.22.5\"\n16: app = marimo.App()\n17: \n18: \n19: @app.cell(hide_code=True)\n20: def _():\n21:     import pandas as pd\n22:     import marimo as mo\n23:     import seaborn as sns\n24:     import matplotlib.pyplot as plt\n25:     from pathlib import Path\n26:     import numpy as np\n27:     import re\n28: \n29:     # For UpSet plot\n30:     try:\n31:         import upsetplot\n32:         from upsetplot import UpSet\n33:     except ImportError:\n34:         upsetplot = None\n35: \n36:     # Set plotting style\n37:     sns.set_style('whitegrid')\n38:     plt.rcParams['figure.figsize'] = (14, 8)\n39:     return Path, mo, pd, plt, sns\n40: \n41: \n42: @app.cell(hide_code=True)\n43: def _(mo):\n44:     mo.md(r\"\"\"\n45:     ## Imports\n46: \n47:     We import the necessary libraries for data manipulation and visualization, including pandas for data handling, seaborn and matplotlib for plotting, and upsetplot for the set intersection visualization.\n48:     \"\"\")\n49:     return\n50: \n51: \n52: @app.cell(hide_code=True)\n53: def _(mo):\n54:     mo.md(r\"\"\"\n55:     ## Data Loading\n56: \n57:     We load the mutation data from the CSV file. Each row contains a mutation in the format `[OriginalAA][Position][MutantAA]` (e.g., A111C), along with activity measurements including the 'mean' column that we will use for our analysis.\n58:     \"\"\")\n59:     return\n60: \n61: \n62: @app.cell(hide_code=True)\n63: def _(Path, pd):\n64:     data_path = Path(\"data/ired-novartis/cs1c02786_si_002.csv\")\n65:     df_raw = pd.read_csv(data_path)\n66:     print(f\"Total rows loaded: {len(df_raw)}\")\n67:     df_raw.head()\n68:     return (df_raw,)\n69: \n70: \n71: @app.cell(hide_code=True)\n72: def _(mo):\n73:     mo.md(r\"\"\"\n74:     ## Parse Single Point Mutations\n75: \n76:     We filter the data to include only single point mutations (no multi-mutations with semicolons) and parse each mutation string to extract:\n77:     - Original amino acid (first letter)\n78:     - Position number (digits in the middle)\n79:     - Mutant amino acid (last letter)\n80: \n81:     This gives us the data structure needed for our heatmap visualization.\n82:     \"\"\")\n83:     return\n84: \n85: \n86: @app.cell(hide_code=True)\n87: def _(df_raw, pd):\n88:     def parse_single_mutation(mutation_str):\n89:         \"\"\"Parse single point mutation like 'A111C' into (original, position, mutant)\"\"\"\n90:         if pd.isna(mutation_str):\n91:             return None, None, None\n92:         mutation_str = str(mutation_str).strip()\n93:         # Skip multi-mutations (contain semicolons)\n94:         if ';' in mutation_str:\n95:             return None, None, None\n96:         # Must be format like A111C (letter, digits, letter)\n97:         if len(mutation_str) < 3:\n98:             return None, None, None\n99:         original = mutation_str[0]\n100:         mutant = mutation_str[-1]\n101:         # Extract digits from middle\n102:         middle = mutation_str[1:-1]\n103:         if not middle.isdigit():\n104:             return None, None, None\n105:         position = int(middle)\n106:         return original, position, mutant\n107: \n108:     # Filter to single point mutations only\n109:     single_mutation_mask = ~df_raw['mutation'].str.contains(';', na=False)\n110:     df_parsed = df_raw[single_mutation_mask].copy()\n111: \n112:     # Parse mutations\n113:     parse_results = df_parsed['mutation'].apply(parse_single_mutation)\n114:     df_parsed['original_aa'] = [p[0] for p in parse_results]\n115:     df_parsed['position'] = [p[1] for p in parse_results]\n116:     df_parsed['mutant_aa'] = [p[2] for p in parse_results]\n117: \n118:     # Remove failed parses\n119:     df_parsed = df_parsed.dropna(subset=['position', 'mutant_aa', 'mean'])\n120: \n121:     print(f\"Total rows in raw data: {len(df_raw)}\")\n122:     print(f\"Single point mutations: {len(df_parsed)}\")\n123:     print(f\"Multi-mutations filtered: {len(df_raw) - len(df_parsed)}\")\n124:     print(f\"\\nUnique positions: {df_parsed['position'].nunique()}\")\n125:     print(f\"Position range: {df_parsed['position'].min()} - {df_parsed['position'].max()}\")\n126:     print(f\"\\nUnique mutant amino acids: {sorted(df_parsed['mutant_aa'].unique())}\")\n127:     print(\"\\nSample data:\")\n128:     df_parsed[['mutation', 'position', 'mutant_aa', 'mean']].head(15)\n129:     return (df_parsed,)\n130: \n131: \n132: @app.cell(hide_code=True)\n133: def _(mo):\n134:     mo.md(r\"\"\"\n135:     ## Mutation Activity Heatmap\n136: \n137:     We create a heatmap showing the mean activity values for each position (x-axis) and mutant amino acid (y-axis). Darker colors indicate higher activity values. This visualization helps identify which positions and mutations have the highest activity.\n138:     \"\"\")\n139:     return\n140: \n141: \n142: @app.cell(hide_code=True)\n143: def _(df_parsed, plt, sns):\n144:     # Create pivot table for heatmap\n145:     # For positions with multiple mutations, we'll show the mean value for each mutant-position pair\n146:     heatmap_data = df_parsed.pivot_table(\n147:         values='mean', \n148:         index='mutant_aa', \n149:         columns='position', \n150:         aggfunc='mean'\n151:     )\n152: \n153:     # Sort positions numerically\n154:     heatmap_data = heatmap_data.reindex(sorted(heatmap_data.columns), axis=1)\n155: \n156:     # Sort mutant amino acids alphabetically\n157:     heatmap_data = heatmap_data.sort_index()\n158: \n159:     # Create the heatmap\n160:     fig, ax = plt.subplots(figsize=(24, 10))\n161:     sns.heatmap(\n162:         heatmap_data, \n163:         cmap='viridis', \n164:         cbar_kws={'label': 'Mean Activity'},\n165:         xticklabels=50,  # Show fewer x-tick labels for readability\n166:         ax=ax\n167:     )\n168:     ax.set_xlabel('Position')\n169:     ax.set_ylabel('Mutant Amino Acid')\n170:     ax.set_title('Mutation Activity Heatmap (Position × Mutant)')\n171:     plt.tight_layout()\n172:     fig\n173:     return\n174: \n175: \n176: @app.cell(hide_code=True)\n177: def _(mo):\n178:     mo.md(r\"\"\"\n179:     ## Rank Order by Average Activity\n180: \n181:     We rank positions by their average 'mean' activity value across all mutations at that position. This helps identify positions that generally show higher activity regardless of the specific mutation. These are positions where multiple mutations can yield good results.\n182:     \"\"\")\n183:     return\n184: \n185: \n186: @app.cell(hide_code=True)\n187: def _(df_parsed):\n188:     # Calculate average mean activity per position\n189:     position_avg = df_parsed.groupby('position')['mean'].mean().sort_values(ascending=False)\n190: \n191:     print(\"Top 20 positions by average activity:\")\n192:     print(\"=\" * 50)\n193:     for i, (pos, val) in enumerate(position_avg.head(20).items(), 1):\n194:         print(f\"{i:2d}. Position {int(pos)}: {val:.6f}\")\n195:     \n196:     position_avg\n197:     return (position_avg,)\n198: \n199: \n200: @app.cell(hide_code=True)\n201: def _(mo):\n202:     mo.md(r\"\"\"\n203:     ## Rank Order by Maximum Activity\n204: \n205:     We rank positions by their maximum 'mean' activity value achieved by any single mutation at that position. This identifies positions where at least one specific mutation yields very high activity, even if other mutations at that position perform poorly.\n206:     \"\"\")\n207:     return\n208: \n209: \n210: @app.cell(hide_code=True)\n211: def _(df_parsed):\n212:     # Calculate maximum mean activity per position\n213:     position_top_values = df_parsed.groupby('position')['mean'].max().sort_values(ascending=False)\n214: \n215:     print(\"Top 20 positions by maximum activity:\")\n216:     print(\"=\" * 60)\n217:     for idx, (pos_val, max_val) in enumerate(position_top_values.head(20).items(), 1):\n218:         # Find which mutation achieved this max\n219:         best_mut = df_parsed[(df_parsed['position'] == pos_val) & (df_parsed['mean'] == max_val)]['mutation'].iloc[0]\n220:         print(f\"{idx:2d}. Position {int(pos_val)}: {max_val:.6f} ({best_mut})\")\n221:     \n222:     position_top_values\n223:     return (position_top_values,)\n224: \n225: \n226: @app.cell(hide_code=True)\n227: def _(mo):\n228:     mo.md(r\"\"\"\n229:     ## UpSet Plot: Comparing Top 20 Rankings\n230: \n231:     We visualize the overlap between the top 20 positions from each ranking method using an UpSet plot. This shows which positions appear in both rankings (the intersection) versus positions unique to each ranking method.\n232:     \"\"\")\n233:     return\n234: \n235: \n236: @app.cell(hide_code=True)\n237: def _(df_parsed, pd, plt, position_avg, position_top_values):\n238:     from upsetplot import UpSet as UpSetPlot, from_memberships\n239: \n240:     # Get top 20 from each ranking\n241:     top20_avg_set = set(position_avg.head(20).index)\n242:     top20_max_set = set(position_top_values.head(20).index)\n243: \n244:     # Create membership data for UpSet plot\n245:     all_positions_upset = sorted(top20_avg_set | top20_max_set)\n246:     memberships_upset = []\n247:     for pos_upset in all_positions_upset:\n248:         member_of_upset = []\n249:         if pos_upset in top20_avg_set:\n250:             member_of_upset.append('Top 20 by Avg')\n251:         if pos_upset in top20_max_set:\n252:             member_of_upset.append('Top 20 by Max')\n253:         memberships_upset.append(member_of_upset)\n254: \n255:     # Count occurrences\n256:     counts_upset = {}\n257:     for m_upset in memberships_upset:\n258:         key_upset = tuple(sorted(m_upset))\n259:         counts_upset[key_upset] = counts_upset.get(key_upset, 0) + 1\n260: \n261:     # Create the UpSet data\n262:     index_upset = pd.MultiIndex.from_tuples([\n263:         ('Top 20 by Avg' in k_upset, 'Top 20 by Max' in k_upset) \n264:         for k_upset in counts_upset.keys()\n265:     ], names=['Top 20 by Avg', 'Top 20 by Max'])\n266: \n267:     upset_data_series = pd.Series(list(counts_upset.values()), index=index_upset)\n268: \n269:     # Sort by degree (number of categories)\n270:     upset_data_series = upset_data_series.sort_index()\n271: \n272:     # Create UpSet plot\n273:     fig_upset = plt.figure(figsize=(10, 6))\n274:     upset_plot = UpSetPlot(upset_data_series, subset_size='count', show_counts=True)\n275:     upset_plot.plot(fig=fig_upset)\n276:     plt.suptitle('Overlap Between Top 20 Positions by Average vs Maximum Activity', y=1.02)\n277:     fig_upset\n278: \n279:     # Print the intersection details\n280:     print(\"Positions in BOTH Top 20 (Average AND Maximum):\")\n281:     print(\"=\" * 55)\n282:     both_sets = sorted(top20_avg_set & top20_max_set)\n283:     for pos_both in both_sets:\n284:         avg_val_both = position_avg[pos_both]\n285:         max_val_both = position_top_values[pos_both]\n286:         best_mut_both = df_parsed[(df_parsed['position'] == pos_both) & (df_parsed['mean'] == max_val_both)]['mutation'].iloc[0]\n287:         print(f\"  Position {int(pos_both)}: avg={avg_val_both:.4f}, max={max_val_both:.4f} ({best_mut_both})\")\n288: \n289:     print(f\"\\n\\nPositions ONLY in Top 20 by Average: {sorted(top20_avg_set - top20_max_set)}\")\n290:     print(f\"\\nPositions ONLY in Top 20 by Maximum: {sorted(top20_max_set - top20_avg_set)}\")\n291:     return\n292: \n293: \n294: if __name__ == \"__main__\":\n295:     app.run()\n\n(End of file - total 295 lines)\n</content>","metadata":{"preview":"# /// script\n# requires-python = \">=3.13\"\n# dependencies = [\n#     \"marimo>=0.22.5\",\n#     \"matplotlib==3.10.8\",\n#     \"numpy==2.4.4\",\n#     \"pandas==3.0.2\",\n#     \"seaborn==0.13.2\",\n#     \"upsetplot==0.9.0\",\n# ]\n# ///\n\nimport marimo\n\n__generated_with = \"0.22.5\"\napp = marimo.App()\n\n\n@app.cell(hide_code=True)\ndef _():","truncated":false,"loaded":[]},"title":"kimi-analysis.py","time":{"start":1775620415303,"end":1775620415308}},"metadata":{"openrouter":{"reasoning_details":[{"type":"reasoning.text","text":"There are conflicts with the existing notebook cells. Let me check the file again and see what's happening. It seems the notebook file has cells that conflict with what I was adding. Let me read the file again to understand the structure.","format":"unknown","index":0}]}}}}
