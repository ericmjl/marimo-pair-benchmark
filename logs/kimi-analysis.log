{"type":"tool_use","timestamp":1775620243525,"sessionID":"ses_294c9a4d9ffeSwOQKf2XzFA0yJ","part":{"id":"prt_d6b36bacc001ularkU0HK67YsT","messageID":"msg_d6b3697da001v0Hqa17OKBLmV9","sessionID":"ses_294c9a4d9ffeSwOQKf2XzFA0yJ","type":"tool","tool":"read","callID":"read:3","state":{"status":"completed","input":{"filePath":"/Users/ericmjl/github/marimo-pair-benchmark/kimi-analysis.py"},"output":"<path>/Users/ericmjl/github/marimo-pair-benchmark/kimi-analysis.py</path>\n<type>file</type>\n<content>\n1: # /// script\n2: # requires-python = \">=3.13\"\n3: # dependencies = [\n4: #     \"marimo>=0.22.5\",\n5: #     \"matplotlib==3.10.8\",\n6: #     \"pandas==3.0.2\",\n7: #     \"seaborn==0.13.2\",\n8: # ]\n9: # ///\n10: \n11: import marimo\n12: \n13: __generated_with = \"0.22.5\"\n14: app = marimo.App()\n15: \n16: \n17: @app.cell\n18: def _():\n19:     return\n20: \n21: \n22: @app.cell(hide_code=True)\n23: def _(mo):\n24:     mo.md(r\"\"\"\n25:     # Single Point Mutation Analysis\n26: \n27:     This notebook analyzes single point mutations from the IRED Novartis dataset.\n28:     We visualize mutation effects as a heatmap and rank positions by their impact.\n29:     \"\"\")\n30:     return\n31: \n32: \n33: @app.cell(hide_code=True)\n34: def _(mo):\n35:     mo.md(r\"\"\"\n36:     ## Imports\n37: \n38:     We import the necessary libraries for data manipulation and visualization.\n39:     \"\"\")\n40:     return\n41: \n42: \n43: @app.cell(hide_code=True)\n44: def _():\n45:     import pandas as pd\n46:     import marimo as mo\n47:     import seaborn as sns\n48:     import matplotlib.pyplot as plt\n49:     from pathlib import Path\n50: \n51:     return Path, mo, pd, plt, sns\n52: \n53: \n54: @app.cell(hide_code=True)\n55: def _(mo):\n56:     mo.md(r\"\"\"\n57:     ## Data Loading\n58: \n59:     We load the mutation data from the CSV file. Each row contains a mutation\n60:     in the format `[OriginalAA][Position][MutantAA]` (e.g., A111C), along with\n61:     activity measurements including the 'mean' column that we will use for our analysis.\n62:     \"\"\")\n63:     return\n64: \n65: \n66: @app.cell(hide_code=True)\n67: def _(Path, pd):\n68:     data_path = Path(\"data/ired-novartis/cs1c02786_si_002.csv\")\n69:     df_raw = pd.read_csv(data_path)\n70:     df_raw.head()\n71:     return (df_raw,)\n72: \n73: \n74: @app.cell(hide_code=True)\n75: def _(mo):\n76:     mo.md(r\"\"\"\n77:     ## Parse Mutation Information\n78: \n79:     We extract the position number and mutant amino acid letter from each mutation string.\n80:     The format is `[OriginalAA][Position][MutantAA]` - we need the position for the x-axis\n81:     and the mutant letter for the y-axis of our heatmap.\n82:     \"\"\")\n83:     return\n84: \n85: \n86: @app.cell(hide_code=True)\n87: def _(mo):\n88:     mo.md(r\"\"\"\n89:     ## Mutation Heatmap\n90: \n91:     We create a heatmap showing the mean activity values for each position (x-axis)\n92:     and mutant amino acid (y-axis). This visualization helps identify which positions\n93:     and mutations have the highest activity.\n94:     \"\"\")\n95:     return\n96: \n97: \n98: @app.cell(hide_code=True)\n99: def _(df_parsed, plt, sns):\n100:     # Create pivot table for heatmap\n101:     # For positions with multiple mutations, we'll show the mean value for each mutant-position pair\n102:     heatmap_data = df_parsed.pivot_table(\n103:         values='mean', \n104:         index='mutant_aa', \n105:         columns='position', \n106:         aggfunc='mean'\n107:     )\n108: \n109:     # Sort positions numerically\n110:     heatmap_data = heatmap_data.reindex(sorted(heatmap_data.columns), axis=1)\n111: \n112:     # Sort mutant amino acids alphabetically\n113:     heatmap_data = heatmap_data.sort_index()\n114: \n115:     # Create the heatmap\n116:     fig, ax = plt.subplots(figsize=(24, 10))\n117:     sns.heatmap(\n118:         heatmap_data, \n119:         cmap='viridis', \n120:         cbar_kws={'label': 'Mean Activity'},\n121:         xticklabels=50,  # Show fewer x-tick labels for readability\n122:         ax=ax\n123:     )\n124:     ax.set_xlabel('Position')\n125:     ax.set_ylabel('Mutant Amino Acid')\n126:     ax.set_title('Mutation Activity Heatmap (Position × Mutant)')\n127:     plt.tight_layout()\n128:     fig\n129:     return\n130: \n131: \n132: @app.cell(hide_code=True)\n133: def _(mo):\n134:     mo.md(r\"\"\"\n135:     ## Rank Order by Average Activity\n136: \n137:     We rank positions by their average 'mean' activity value across all mutations at that position.\n138:     This helps identify positions that generally show higher activity regardless of the specific mutation.\n139:     \"\"\")\n140:     return\n141: \n142: \n143: @app.cell(hide_code=True)\n144: def _(df_parsed):\n145:     # Calculate average mean activity per position\n146:     position_avg = df_parsed.groupby('position')['mean'].mean().sort_values(ascending=False)\n147: \n148:     print(\"Top 20 positions by average activity:\")\n149:     print(\"=\" * 50)\n150:     for i, (pos, val) in enumerate(position_avg.head(20).items(), 1):\n151:         print(f\"{i:2d}. Position {pos}: {val:.6f}\")\n152:     \n153:     position_avg\n154:     return\n155: \n156: \n157: @app.cell(hide_code=True)\n158: def _(df_raw, pd):\n159:     def parse_single_mutation(mutation_str):\n160:         \"\"\"Parse single point mutation like 'A111C' into (original, position, mutant)\"\"\"\n161:         if pd.isna(mutation_str):\n162:             return None, None, None\n163:         mutation_str = str(mutation_str).strip()\n164:         # Skip multi-mutations (contain semicolons)\n165:         if ';' in mutation_str:\n166:             return None, None, None\n167:         # Must be format like A111C (letter, digits, letter)\n168:         if len(mutation_str) < 3:\n169:             return None, None, None\n170:         original = mutation_str[0]\n171:         mutant = mutation_str[-1]\n172:         # Extract digits from middle\n173:         middle = mutation_str[1:-1]\n174:         if not middle.isdigit():\n175:             return None, None, None\n176:         position = int(middle)\n177:         return original, position, mutant\n178: \n179:     # Filter to single point mutations only\n180:     single_mutation_mask = ~df_raw['mutation'].str.contains(';', na=False)\n181:     df_parsed = df_raw[single_mutation_mask].copy()\n182: \n183:     # Parse mutations\n184:     parse_results = df_parsed['mutation'].apply(parse_single_mutation)\n185:     df_parsed['original_aa'] = [p[0] for p in parse_results]\n186:     df_parsed['position'] = [p[1] for p in parse_results]\n187:     df_parsed['mutant_aa'] = [p[2] for p in parse_results]\n188: \n189:     # Remove failed parses\n190:     df_parsed = df_parsed.dropna(subset=['position', 'mutant_aa', 'mean'])\n191: \n192:     print(f\"Total rows in raw data: {len(df_raw)}\")\n193:     print(f\"Single point mutations: {len(df_parsed)}\")\n194:     print(f\"Multi-mutations filtered: {len(df_raw) - len(df_parsed)}\")\n195:     print(f\"\\nUnique positions: {df_parsed['position'].nunique()}\")\n196:     print(f\"Position range: {df_parsed['position'].min()} - {df_parsed['position'].max()}\")\n197:     print(\"\\nSample data:\")\n198:     df_parsed[['mutation', 'position', 'mutant_aa', 'mean']].head(15)\n199:     return (df_parsed,)\n200: \n201: \n202: @app.cell(hide_code=True)\n203: def _(df_parsed):\n204:     # Calculate maximum mean activity per position\n205:     position_top_values = df_parsed.groupby('position')['mean'].max().sort_values(ascending=False)\n206: \n207:     print(\"Top 20 positions by maximum activity:\")\n208:     print(\"=\" * 60)\n209:     for idx, (pos_val, max_val) in enumerate(position_top_values.head(20).items(), 1):\n210:         # Find which mutation achieved this max\n211:         best_mut = df_parsed[(df_parsed['position'] == pos_val) & (df_parsed['mean'] == max_val)]['mutation'].iloc[0]\n212:         print(f\"{idx:2d}. Position {int(pos_val)}: {max_val:.6f} ({best_mut})\")\n213:     \n214:     position_top_values\n215:     return\n216: \n217: \n218: if __name__ == \"__main__\":\n219:     app.run()\n\n(End of file - total 219 lines)\n</content>","metadata":{"preview":"# /// script\n# requires-python = \">=3.13\"\n# dependencies = [\n#     \"marimo>=0.22.5\",\n#     \"matplotlib==3.10.8\",\n#     \"pandas==3.0.2\",\n#     \"seaborn==0.13.2\",\n# ]\n# ///\n\nimport marimo\n\n__generated_with = \"0.22.5\"\napp = marimo.App()\n\n\n@app.cell\ndef _():\n    return\n","truncated":false,"loaded":[]},"title":"kimi-analysis.py","time":{"start":1775620243516,"end":1775620243524}}}}
