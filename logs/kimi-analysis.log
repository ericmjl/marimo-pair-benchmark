ter - they are adjacent and may interact\n341:     4. **Use Tier 2 positions** for saturation mutagenesis libraries since multiple mutations work well there\n342:     \"\"\")\n343:     return\n344: \n345: \n346: @app.cell(hide_code=True)\n347: def _(df_parsed, position_avg, position_top_values):\n348:     print(\"=\" * 80)\n349:     print(\"SUMMARY: RECOMMENDED POSITIONS TO MUTATE\")\n350:     print(\"=\" * 80)\n351: \n352:     # Tier 1: In both top 20s\n353:     tier1_positions = sorted(set(position_avg.head(20).index) & set(position_top_values.head(20).index))\n354:     print(f\"\\n🎯 TIER 1 - Both High Average AND High Maximum ({len(tier1_positions)} positions):\")\n355:     print(\"-\" * 60)\n356:     for pos in tier1_positions:\n357:         avg_val = position_avg[pos]\n358:         max_val = position_top_values[pos]\n359:         best_mut = df_parsed[(df_parsed['position'] == pos) & (df_parsed['mean'] == max_val)]['mutation'].iloc[0]\n360:         print(f\"  Position {int(pos):3d}: avg={avg_val:.4f}, max={max_val:.4f} | Best: {best_mut}\")\n361: \n362:     # Tier 2: High average only\n363:     tier2_positions = sorted(set(position_avg.head(20).index) - set(position_top_values.head(20).index))\n364:     print(f\"\\n📊 TIER 2 - High Average Only ({len(tier2_positions)} positions):\")\n365:     print(\"-\" * 60)\n366:     for pos in tier2_positions:\n367:         avg_val = position_avg[pos]\n368:         print(f\"  Position {int(pos):3d}: avg={avg_val:.4f}\")\n369: \n370:     # Tier 3: High maximum only\n371:     tier3_positions = sorted(set(position_top_values.head(20).index) - set(position_avg.head(20).index))\n372:     print(f\"\\n🚀 TIER 3 - High Maximum Only ({len(tier3_positions)} positions):\")\n373:     print(\"-\" * 60)\n374:     for pos in tier3_positions:\n375:         max_val = position_top_values[pos]\n376:         best_mut = df_parsed[(df_parsed['position'] == pos) & (df_parsed['mean'] == max_val)]['mutation'].iloc[0]\n377:         print(f\"  Position 