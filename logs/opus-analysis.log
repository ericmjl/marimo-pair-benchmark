_positions = range(len(subset_sizes))\\n\"\n                \"bars = ax_bar.bar(x_positions, subset_sizes, color=['#4878CF', '#6ACC65', '#D65F5F'], width=0.6)\\n\"\n                \"for bar_item, count in zip(bars, subset_sizes):\\n\"\n                \"    ax_bar.text(bar_item.get_x() + bar_item.get_width()/2, bar_item.get_height() + 0.2,\\n\"\n                \"               str(count), ha='center', va='bottom', fontweight='bold', fontsize=12)\\n\"\n                \"ax_bar.set_ylabel('Intersection Size', fontsize=11)\\n\"\n                \"ax_bar.set_xticks([])\\n\"\n                \"ax_bar.set_xlim(-0.5, len(subset_sizes) - 0.5)\\n\"\n                \"ax_bar.spines['top'].set_visible(False)\\n\"\n                \"ax_bar.spines['right'].set_visible(False)\\n\"\n                \"\\n\"\n                \"# Bottom: dot matrix showing set membership\\n\"\n                \"ax_matrix = fig_upset.add_subplot(gs[1])\\n\"\n                \"for col_idx, membership in enumerate(subset_membership):\\n\"\n                \"    for row_idx, is_member in enumerate(membership):\\n\"\n                \"        color = '#333333' if is_member else '#cccccc'\\n\"\n                \"        ax_matrix.scatter(col_idx, row_idx, s=200, c=color, zorder=3)\\n\"\n                \"    # Draw line connecting active dots\\n\"\n                \"    active = [r for r, m in enumerate(membership) if m]\\n\"\n                \"    if len(active) > 1:\\n\"\n                \"        ax_matrix.plot([col_idx, col_idx], [min(active), max(active)],\\n\"\n                \"                       c='#333333', linewidth=2, zorder=2)\\n\"\n                \"\\n\"\n                \"ax_matrix.set_yticks(range(len(set_names)))\\n\"\n                \"ax_matrix.set_yticklabels(set_names, fontsize=10)\\n\"\n                \"ax_matrix.set_xticks([])\\n\"\n                \"ax_matrix.set_xlim(-0.5, len(subset_sizes) - 0.5)\\n\"\n                \"ax_matrix.set_ylim(-0.5, len(set_names) - 0.5)\\n\"\n                \"ax_matrix.spines['top'].set_visible(False)\\n\"\n                \"ax_matrix.spines['right'].set_visible(False)\\n\"\n                \"ax_matrix.spines['bottom'].set_visible(False)\\n\"\n                \"\\n\"\n                \"fig_upset.suptitle('UpSet Plot: Top 20 Positions by Average vs Max Mean Activity',\\n\"\n                \"                   fontsize=13, fontweight='bold')\\n\"\n                \"plt.tight_layout()\\n\"\n                \"fig_upset\"\n            )\n            ctx.run_cell(cid)\n            print(f\"Edited and re-ran cell {cid}\")\n            break\nPYEOF","description":"Build UpSet plot manually with matplotlib"},"output":"Edited and re-ran cell zYXi\n/var/folders/36/vb250n_s0zncstw3sk74qfxr0000gn/T/marimo_70806/__marimo__cell_zYXi_.py:57: UserWarning: This figure includes Axes that are not compatible with tight_layout, so results might be incorrect.\n  plt.tight_layout()\nedited code of cell 'zYXi' (_) and ran\n\n","metadata":{"output":"Edited and re-ran cell zYXi\n/var/folders/36/vb250n_s0zncstw3sk74qfxr0000gn/T/marimo_70806/__marimo__cell_zYXi_.py:57: UserWarning: This figure includes Axes that are not compatible with tight_layout, so results might be incorrect.\n  plt.tight_layout()\nedited code of cell 'zYXi' (_) and ran\n\n","exit":0,"description":"Build UpSet plot manually with matplotlib","truncated":false},"title":"Build UpSet plot manually with matplotlib","time":{"start":1775620496424,"end":1775620496680}},"metadata":{"openrouter":{"reasoning_details":[]}}}}
